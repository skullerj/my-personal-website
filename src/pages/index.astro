---
import { Image } from "astro:assets";
import me from "@assets/me.png";
import profile from "@assets/profile.json";
import socialIcons from "@assets/socialIcons";
import BentoCard from "@components/BentoCard.astro";
import Button from "@components/Button.astro";
import ThemeToggle from "@components/ThemeToggle.astro";
import { SOCIALS } from "@config";
import Layout from "@layouts/Layout.astro";

const activeSocials = SOCIALS.filter((s) => s.active);
const lastDeployed = new Date(profile.ambient.lastDeployed).toLocaleDateString(
  "en-GB",
  { day: "numeric", month: "short", year: "numeric" }
);
---

<Layout>
  <div class="grid grid-cols-12 gap-4 max-w-7xl mx-auto px-4 py-8">
    <!-- Card 1: About (two-thirds) -->
    <BentoCard span="two-thirds" label="// ABOUT">
      <div class="flex items-start gap-4 mb-4">
        <Image
          src={me}
          alt="Juan Rosero"
          class="w-12 h-12 rounded-full object-cover flex-shrink-0"
        />
        <div>
          <h1 class="text-2xl font-semibold text-text-primary leading-tight">
            {profile.personalInfo.name}
          </h1>
          <p class="font-mono text-xs text-text-mono mt-0.5">
            {profile.personalInfo.title}
          </p>
        </div>
      </div>
      <p class="text-sm text-text-secondary leading-relaxed mb-4">
        {profile.professionalSummary}
      </p>
      <div class="flex flex-wrap items-center gap-4 mt-4">
        <span class="font-mono text-xs text-text-mono"
          >{profile.personalInfo.location}</span
        >
        <span class="font-mono text-xs text-text-mono"
          >{profile.personalInfo.email}</span
        >
        {
          activeSocials.map((social) => (
            <a
              href={social.href}
              title={social.linkTitle}
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-secondary hover:text-accent transition-colors duration-200"
              set:html={socialIcons[social.name]}
            />
          ))
        }
        <span
          class="inline-flex items-center gap-1.5 text-xs font-mono text-accent border border-accent/30 rounded-full px-2.5 py-1"
        >
          <span class="pulse-dot w-1.5 h-1.5 rounded-full bg-accent"
          ></span>
          Open to work
        </span>
      </div>
    </BentoCard>

    <!-- Card 2: Currently Building (third) -->
    <BentoCard span="third" label="// NOW">
      <div class="flex items-start justify-between mb-3">
        <h2 class="text-base font-semibold text-text-primary leading-snug">
          {profile.ambient.currentlyBuilding.title}
        </h2>
        <span
          class="ml-3 flex-shrink-0 inline-flex items-center gap-1.5 text-xs font-mono text-accent border border-accent/30 rounded-full px-2 py-0.5"
        >
          <span class="pulse-dot w-1.5 h-1.5 rounded-full bg-accent"
          ></span>
          {profile.ambient.currentlyBuilding.tag}
        </span>
      </div>
      <p class="text-sm text-text-secondary leading-relaxed">
        {profile.ambient.currentlyBuilding.description}
      </p>
    </BentoCard>

    <!-- Cards 3+: Experience (half each) -->
    {
      profile.experience.map((job) => (
        <BentoCard span="half" label="// EXP">
          <div class="mb-3">
            <h2 class="text-base font-semibold text-text-primary">
              {job.position}
            </h2>
            <p class="text-sm text-text-secondary mt-0.5">
              {job.company} &bull; {job.location}
            </p>
            <span class="font-mono text-xs text-text-mono">{job.duration}</span>
          </div>
          <p class="text-sm text-text-secondary leading-relaxed mb-4">
            {job.description}
          </p>
          <div class="flex flex-wrap gap-1.5">
            {job.technologies.map((tech) => (
              <span class="font-mono text-xs bg-surface border border-border rounded px-2 py-0.5 text-text-secondary">
                {tech}
              </span>
            ))}
          </div>
        </BentoCard>
      ))
    }

    <!-- Card: Skills (full) -->
    <BentoCard span="full" label="// STACK">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          profile.technicalSkills.map((category) => (
            <div>
              <span class="block font-mono text-xs text-text-mono mb-3 uppercase tracking-wider">
                {category.label}
              </span>
              <div class="flex flex-wrap gap-1.5">
                {category.entries.map((entry) => (
                  <span class="font-mono text-xs bg-surface border border-border rounded px-2 py-0.5 text-text-secondary">
                    {entry}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </BentoCard>

    <!-- Card: Thinking About (half) -->
    <BentoCard span="half" label="// THINKING">
      <h2 class="text-base font-semibold text-text-primary mb-3">
        {profile.ambient.thinkingAbout.title}
      </h2>
      <p class="text-sm text-text-secondary leading-relaxed">
        {profile.ambient.thinkingAbout.description}
      </p>
    </BentoCard>

    <!-- Card: Contact (full) -->
    <BentoCard span="full" label="// CONTACT">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <h2 class="text-base font-semibold text-text-primary mb-1">
            Get In Touch
          </h2>
          <p class="text-sm text-text-secondary">
            Reach out if you'd like to collaborate or have a question.
          </p>
        </div>
        <div class="flex items-center gap-3 flex-wrap">
          <Button variant="primary" href={`mailto:${profile.personalInfo.email}`}>
            Get In Touch
          </Button>
          <Button variant="secondary" href="/resume.pdf">
            Get Resume
          </Button>
          <ThemeToggle />
        </div>
      </div>
      <div class="mt-4 pt-4 border-t border-border">
        <span class="font-mono text-xs text-text-mono"
          >Last deployed: {lastDeployed}</span
        >
      </div>
    </BentoCard>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray(".bento-card").forEach((card) => {
    gsap.from(card as HTMLElement, {
      y: 16,
      opacity: 0,
      duration: 0.5,
      ease: "power2.out",
      scrollTrigger: {
        trigger: card as HTMLElement,
        start: "top 88%",
        toggleActions: "play none none none",
      },
    });
  });
</script>
